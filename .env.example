# AegisAI 环境变量配置示例
# 复制此文件为 .env.local（不提交到版本控制），按需修改

# ── API 基础路径 ──────────────────────────────
# 开发时 Vite 会将 /api 代理到后端地址（见 vite.config.js）
VITE_API_BASE=/api

# ── Mock 模式 ─────────────────────────────────
# 设置为 true 时，仅登录链路使用模拟会话，
# 首页与敏感扫描页会自动切换到演示数据兜底。
# 集成调试或正式部署时请设为 false。
VITE_USE_MOCK=false

# ── 应用信息 ──────────────────────────────────
VITE_APP_TITLE=AegisAI 数据治理平台
VITE_APP_VERSION=1.0.0
