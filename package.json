{
  "name": "trustai-frontend",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "electron:dev": "electron .",
    "electron:build": "electron-builder --win --x64",
    "dist": "npm run build && npm run electron:build"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.6.0",
    "echarts": "^5.6.0",
    "element-plus": "^2.5.0",
    "gsap": "^3.12.5",
    "node-cron": "^3.0.3",
    "ogl": "^1.0.11",
    "pinia": "^2.1.0",
    "three": "^0.178.0",
    "uuid": "^9.0.1",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@pact-foundation/pact": "^13.2.0",
    "@playwright/test": "1.53.0",
    "@vitejs/plugin-vue": "^4.5.0",
    "@vue/eslint-config-prettier": "^8.0.0",
    "electron": "^28.2.8",
    "electron-builder": "^26.8.1",
    "eslint": "^8.56.0",
    "vite": "^4.5.0"
  },
  "build": {
    "appId": "com.aegis.workbench",
    "productName": "Aegis Workbench",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
