{
  "name": "trustai-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "lint": "eslint . --ext .js,.vue,.ts",
    "security:scan": "node scripts/check-sensitive-logs.mjs",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:backend:integration": "cd backend && mvn -q \"-Dtest=AccountApprovalIntegrationTest,DashboardSecurityIntegrationTest,ValidationGuardIntegrationTest,PermissionMatrixIntegrationTest\" test",
    "verify:ci": "npm run security:scan && npm run build && npm run test:backend:integration && npm run test:e2e"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.6.0",
    "echarts": "^5.6.0",
    "element-plus": "^2.5.0",
    "gsap": "^3.12.5",
    "ogl": "^1.0.11",
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@playwright/test": "1.53.0",
    "@vitejs/plugin-vue": "^4.5.0",
    "@vue/eslint-config-prettier": "^8.0.0",
    "electron": "^28.2.8",
    "electron-builder": "^26.8.1",
    "eslint": "^8.56.0",
    "vite": "^4.5.0"
  }
}
