# 开发模式 Dockerfile
FROM node:18-alpine
WORKDIR /app

# 复制依赖清单
COPY package*.json ./

# 安装依赖
RUN npm install --legacy-peer-deps

# 复制源代码
COPY src ./src
COPY index.html .
COPY vite.config.js .

# 环境变量
ENV VITE_API_BASE_URL=http://localhost:8080

# 暴露端口
EXPOSE 3000

# 运行开发服务器
CMD ["npm", "run", "dev", "--", "--host"]
